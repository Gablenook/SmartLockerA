<UserControl x:Class="Keypad.NumericKeypadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto"
             Width="Auto"
             Background="Transparent">

    <UserControl.Resources>

        <!-- Local fallback resources so the control still renders
             even if a consuming window/theme forgets to provide them -->
        <SolidColorBrush x:Key="BrandKeypadPanelBrush" Color="White"/>
        <SolidColorBrush x:Key="BrandKeypadButtonBrush" Color="#C9C9C9"/>
        <SolidColorBrush x:Key="BrandKeypadButtonTextBrush" Color="#111111"/>
        <SolidColorBrush x:Key="BrandKeypadSpecialBrush" Color="#BFC3C7"/>
        <SolidColorBrush x:Key="BrandKeypadEnterBrush" Color="#CE2028"/>
        <SolidColorBrush x:Key="BrandKeypadEnterTextBrush" Color="White"/>

        <DropShadowEffect x:Key="FallbackShadowEffect"
                          Color="#80000000"
                          BlurRadius="10"
                          ShadowDepth="2"
                          Opacity="0.35"/>

        <Style x:Key="KeypadBaseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BrandKeypadButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrandKeypadButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrandKeypadButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="34"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KeypadDigitButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource KeypadBaseButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrandKeypadButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrandKeypadButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrandKeypadButtonTextBrush}"/>
        </Style>

        <Style x:Key="KeypadSpecialButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource KeypadBaseButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrandKeypadSpecialBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrandKeypadSpecialBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrandKeypadButtonTextBrush}"/>
        </Style>

        <Style x:Key="KeypadEnterButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource KeypadBaseButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BrandKeypadEnterBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrandKeypadEnterBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrandKeypadEnterTextBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

    </UserControl.Resources>

    <Border Padding="8"
            CornerRadius="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="280"
            Background="{DynamicResource BrandKeypadPanelBrush}"
            Effect="{DynamicResource ShadowEffect}">

        <Grid Margin="3"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content="2" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="3" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>

            <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>

            <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>

            <Button Grid.Row="3" Grid.Column="0" Content="CLR" Style="{StaticResource KeypadSpecialButtonStyle}" Click="Clear_Click"/>
            <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource KeypadDigitButtonStyle}" Click="Digit_Click"/>
            <Button Grid.Row="3" Grid.Column="2" Content="←" Style="{StaticResource KeypadSpecialButtonStyle}" Click="Backspace_Click"/>

            <Button Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Content="ENTER"
                    Style="{StaticResource KeypadEnterButtonStyle}"
                    Click="Submit_Click"/>
        </Grid>
    </Border>
</UserControl>
