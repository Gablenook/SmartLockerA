<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base -->
    <Color x:Key="BrandBackgroundColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="BrandBackgroundBrush" Color="{StaticResource BrandBackgroundColor}"/>

    <!-- Primary actions -->
    <SolidColorBrush x:Key="BrandPrimaryButtonBrush" Color="#111111"/>
    <SolidColorBrush x:Key="BrandPrimaryButtonTextBrush" Color="White"/>
    <SolidColorBrush x:Key="BrandSecondaryButtonBrush" Color="#555555"/>

    <!-- Prompt -->
    <SolidColorBrush x:Key="BrandPromptBrush" Color="#EFC7CA"/>
    <SolidColorBrush x:Key="BrandPromptTextBrush" Color="#111111"/>

    <!-- Optional header accent -->
    <SolidColorBrush x:Key="BrandHeaderAccentBrush" Color="#CE2028"/>

    <!-- Tile outline -->
    <SolidColorBrush x:Key="BrandTileOutlineBrush" Color="#BBBBBB"/>

    <!-- Keypad -->
    <SolidColorBrush x:Key="BrandKeypadButtonBrush" Color="#C9C9C9"/>
    <SolidColorBrush x:Key="BrandKeypadButtonTextBrush" Color="#111111"/>
    <SolidColorBrush x:Key="BrandKeypadSpecialBrush" Color="#BFC3C7"/>
    <SolidColorBrush x:Key="BrandKeypadEnterBrush" Color= "#C61D25"/>
    <SolidColorBrush x:Key="BrandKeypadPanelBrush" Color="White"/>
    <SolidColorBrush x:Key="BrandKeypadEnterTextBrush" Color="White"/>

    <!-- Logo -->
    <BitmapImage x:Key="BrandLogoImage"  UriSource="/Images/Ryder.png"/>

</ResourceDictionary>