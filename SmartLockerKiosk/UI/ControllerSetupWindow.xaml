<Window x:Class="SmartLockerKiosk.ControllerSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controller Setup"
        WindowStartupLocation="CenterOwner"
        Width="800"
        Height="1200"
        MinWidth="800"
        MinHeight="1200"
        ResizeMode="NoResize"
        WindowStyle="None"
        Topmost="True"
        Background="#00205B">

    <Window.Resources>

        <!-- If your app already has these styles in App.xaml, remove these local definitions.
             They are here so this window compiles even if opened standalone. -->

        <Style x:Key="NormalActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0B5FA8"/>
            <Setter Property="BorderBrush" Value="#083E6D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CallToActionButtonStyle" TargetType="Button" BasedOn="{StaticResource NormalActionButtonStyle}">
            <Setter Property="Background" Value="#0D6EBD"/>
            <Setter Property="BorderBrush" Value="#0A4E86"/>
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#173A66"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="26"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#102E52"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

    </Window.Resources>

    <Grid Margin="60">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Card -->
            <RowDefinition Height="*"/>
            <!-- Status -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Commissioning"
                       Foreground="White"
                       FontSize="44"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Step 3 — Controller Detection &amp; Branch Assignment"
                       Foreground="White"
                       FontSize="22"
                       Opacity="0.85"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Main card -->
        <Border Grid.Row="1" Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Detect -->
                    <RowDefinition Height="18"/>
                    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- Assign -->
                    <RowDefinition Height="18"/>
                    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- Actions -->
                </Grid.RowDefinitions>

                <!-- Detect -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title -->
                        <RowDefinition Height="Auto"/>
                        <!-- Content -->
                        <RowDefinition Height="Auto"/>
                        <!-- Tip -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleStyle}" Text="Detect Controllers"/>

                    <Grid Grid.Row="1" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="DetectButton"
                        Grid.Column="0"
                        Content="Detect Controllers"
                        Width="260"
                        Margin="0,0,16,0"
                        Style="{StaticResource CallToActionButtonStyle}"
                        Click="DetectControllers_Click"/>

                        <Border Grid.Column="1"
                        Background="#102E52"
                        CornerRadius="12"
                        Padding="10">
                            <ListBox x:Name="PortsListBox"
                             Height="120"/>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="2"
                       Foreground="White"
                       Opacity="0.75"
                       FontSize="18"
                       Margin="0,14,0,0"
                       Text="Tip: If nothing is detected, verify USB/RS-232 adapters, power, and COM port visibility."/>
                </Grid>

                <!-- Assign -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title -->
                        <RowDefinition Height="Auto"/>
                        <!-- Form -->
                        <RowDefinition Height="Auto"/>
                        <!-- Tip -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleStyle}" Text="Assign Branch Ports"/>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource LabelStyle}"
                           Text="Branch A (required):"
                           Margin="0,0,14,14"/>

                        <ComboBox x:Name="BranchAComboBox"
                          Grid.Row="0" Grid.Column="1"
                          Margin="0,0,0,14"
                          MinWidth="260"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                           Style="{StaticResource LabelStyle}"
                           Text="Branch B (required if multiple controllers detected):"
                           Margin="0,0,14,0"/>

                        <ComboBox x:Name="BranchBComboBox"
                          Grid.Row="1" Grid.Column="1"
                          MinWidth="260"/>
                    </Grid>

                    <TextBlock Grid.Row="2"
                       Foreground="White"
                       Opacity="0.75"
                       FontSize="18"
                       Margin="0,14,0,0"
                       Text="Branch A is required. If multiple controllers are detected, Branch B must also be assigned."/>
                </Grid>

                <!-- Actions -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="LoadSavedButton"
                    Grid.Column="0"
                    Content="Load Saved"
                    Width="180"
                    Margin="0,0,12,0"
                    Style="{StaticResource NormalActionButtonStyle}"
                    Click="LoadSaved_Click"/>

                    <Button x:Name="SaveButton"
                    Grid.Column="1"
                    Content="Save &amp; Continue"
                    Width="240"
                    Style="{StaticResource CallToActionButtonStyle}"
                    Click="SavePorts_Click"/>

                    <Button Grid.Column="3"
                    Content="Back"
                    Width="160"
                    Style="{StaticResource NormalActionButtonStyle}"
                    Click="Close_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Status area -->
        <Border Grid.Row="2"
                Background="Transparent"
                Margin="0,20,0,20">
            <TextBox x:Name="StatusText"
                     Text="Step 3: Detect controllers, assign Branch A/B, then Save &amp; Continue."
                     Foreground="White"
                     Background="Transparent"
                     BorderThickness="0"
                     IsReadOnly="True"
                     IsHitTestVisible="False"
                     FontSize="22"
                     TextWrapping="Wrap"/>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <!-- If you want a true Cancel here, wire it to Close_Click or a dedicated cancel handler -->
            <Button Content="Cancel"
                    Width="160"
                    Style="{StaticResource NormalActionButtonStyle}"
                    Click="Close_Click"/>
        </StackPanel>

    </Grid>
</Window>
