<Window x:Class="SmartLockerKiosk.LockerAccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:keypad="clr-namespace:Keypad;assembly=Keypad"
        Topmost="True"
        Title="Locker Access"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Normal"
        Width="800"
        Height="1200"
        Background="{DynamicResource BrandBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="LockerAccessWindow_Loaded">
  
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/RyderTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="FadeInPrompt">
                <DoubleAnimation Storyboard.TargetName="UserPromptText"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:3"/>
            </Storyboard>

            <DropShadowEffect x:Key="PromptShadowEffect"
                          Color="#F0F4F8"
                          BlurRadius="100"
                          ShadowDepth="0.25"
                          Opacity="0.5"/>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource BrandPrimaryButtonBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource BrandPrimaryButtonTextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                        CornerRadius="18"
                        SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <Style x:Key="WorkflowButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryActionButtonStyle}">
                <Setter Property="Width" Value="300"/>
                <Setter Property="Height" Value="100"/>
                <Setter Property="FontSize" Value="48"/>
                <Setter Property="Margin" Value="10,0"/>
            </Style>

            <Style x:Key="DialogButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryActionButtonStyle}">
                <Setter Property="Width" Value="180"/>
                <Setter Property="Height" Value="90"/>
                <Setter Property="FontSize" Value="34"/>
                <Setter Property="Margin" Value="12,0"/>
            </Style>

            <Style x:Key="SizeTileButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryActionButtonStyle}">
                <Setter Property="Width" Value="200"/>
                <Setter Property="Height" Value="120"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="Padding" Value="12"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    

    <Grid x:Name="RootGrid">

        <!-- HID capture box (not scaled, not visible) -->
        <TextBox x:Name="HidInputBox"
                 Opacity="0"
                 Width="1"
                 Height="1"
                 IsTabStop="False"
                 Focusable="True"
                 VerticalAlignment="Top"
                 HorizontalAlignment="Left" />

        <Viewbox Stretch="Uniform">
            <Grid Width="800" Height="1200" Background="{DynamicResource BrandBackgroundBrush}">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid x:Name="HeaderArea" Grid.Row="0" Margin="20" Panel.ZIndex="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="225" Height="225"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top">
                        <Image Source="{DynamicResource BrandLogoImage}"
       RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Viewbox>

                    <Button Grid.Column="2"
                            Content="X"
                            Width="40"
                            Height="40"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="Red"
                            Foreground="White"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Click="CloseButton_Click"
                            Margin="0,10,10,0"/>
                </Grid>

                <!-- Main -->
                <Grid x:Name="MainContentArea"
                      Grid.Row="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Margin="0,10,0,10"
                      Width="700">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Workflow Buttons -->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,6,0,6">
                        <Button x:Name="DeliverButton"
                                Style="{StaticResource WorkflowButtonStyle}"
                                Content="DELIVER"
                                Click="DeliverButton_Click"/>
                        <Button x:Name="PickupButton"
                                Style="{StaticResource WorkflowButtonStyle}"
                                Content="PICKUP"
                                Click="PickupButton_Click"/>
                    </StackPanel>

                    <!-- Prompt -->
                    <Border Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="625"
                            MinHeight="100"
                            MaxHeight="220"
                            Margin="0,10,0,10"
                            Background="{DynamicResource BrandPromptBrush}"
                            CornerRadius="40"
                            Padding="20"
                            Effect="{DynamicResource PromptShadowEffect}">
                        <TextBlock x:Name="UserPromptText"
                                   Text="Select Transaction Type"
                                   Opacity=".8"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrandPromptTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextTrimming="None"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Keypad + Overlays -->
                    <Grid Grid.Row="2" Margin="0,0,0,0">

                        <!-- Keypad always stays full-size -->
                        <Viewbox Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Stretch"
                                 Margin="0,0,0,0">
                            <keypad:NumericKeypadControl x:Name="KeypadControl"/>
                        </Viewbox>

                        <!-- Size Selection Overlay -->
                        <Border x:Name="SizeSelectionPanel"
                                Background="#D0203A5A"
                                CornerRadius="24"
                                Padding="18"
                                Margin="10,10,10,10"
                                Visibility="Collapsed"
                                Panel.ZIndex="10"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Stretch"
                                MaxHeight="430">

                            <StackPanel>
                                <TextBlock Text="Select Compartment Size"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,14"/>

                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="340">
                                    <ItemsControl x:Name="SizeTilesItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource SizeTileButtonStyle}"
                                                        Click="SizeTile_Click"
                                                        Tag="{Binding SizeCode}">

                                                    <Grid Margin="4">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Text="{Binding DisplayName}"
                                                                   FontSize="24"
                                                                   FontWeight="Bold"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,0,0,4"/>

                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding DimText}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Opacity="0.95"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,0,0,8"/>

                                                        <Border Grid.Row="2"
                                                                Width="{Binding ThumbWidth}"
                                                                Height="{Binding ThumbHeight}"
                                                                BorderBrush="{DynamicResource BrandTileOutlineBrush}"
                                                                BorderThickness="2"
                                                                CornerRadius="8"
                                                                Opacity="0.85"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <!-- Deliver Another Overlay -->
                        <Border x:Name="DeliverAnotherPanel"
                                Background="#D0203A5A"
                                CornerRadius="24"
                                Padding="20"
                                Margin="40,120,40,120"
                                Visibility="Collapsed"
                                Panel.ZIndex="20"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch">

                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Deliver Another?"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           TextAlignment="Center"
                                           Margin="0,0,0,8"/>

                                <TextBlock x:Name="DeliverAnotherCountdownText"
                                           Text="Returning to start in 15 seconds."
                                           FontSize="20"
                                           Foreground="White"
                                           Opacity="0.9"
                                           TextAlignment="Center"
                                           Margin="0,0,0,20"/>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <Button x:Name="DeliverAnotherYesButton"
                                            Style="{StaticResource DialogButtonStyle}"
                                            Content="YES"
                                            Click="DeliverAnotherYesButton_Click"/>

                                    <Button x:Name="DeliverAnotherNoButton"
                                            Style="{StaticResource DialogButtonStyle}"
                                            Content="NO"
                                            Background="{DynamicResource BrandSecondaryButtonBrush}"
                                            Click="DeliverAnotherNoButton_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Grid>

                <!-- Footer -->
                <Grid x:Name="FooterArea"
                      Grid.Row="2"
                      Margin="500,10,0,10"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Panel.ZIndex="999"
                      IsHitTestVisible="True">

                    <Ellipse Width="200"
                             Height="62"
                             Fill="White"
                             Opacity="0.20"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Margin="50,10,0,0"
                             IsHitTestVisible="False"/>

                    <Border Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonUp="AdminLogo_MouseLeftButtonUp"
                            Width="280"
                            Height="110"
                            Panel.ZIndex="1000"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="True">
                        <Image Source="/Images/BrandingLogo.png"
                               Width="250"
                               Height="90"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                            <Image.Effect>
                                <DropShadowEffect Color="White"
                                                  BlurRadius="12"
                                                  ShadowDepth="0.25"
                                                  Opacity="0.75"/>
                            </Image.Effect>
                        </Image>
                    </Border>
                </Grid>

            </Grid>
        </Viewbox>
    </Grid>
</Window>

