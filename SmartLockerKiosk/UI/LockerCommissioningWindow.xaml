<Window x:Class="SmartLockerKiosk.LockerCommissioningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SmartLockerKiosk"
        Title="Locker Commissioning"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#00205B">
    
    <Window.Resources>

    <!-- Normal button style (keeps default look, but ensures consistent sizing if you want later) -->
    <Style x:Key="NormalActionButtonStyle" TargetType="Button">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
    </Style>

        <local:OneBasedIndexConverter x:Key="OneBasedIndexConverter"/>

        <!-- "Push Me!" style: bright + subtle pulsing -->
    <Style x:Key="CallToActionButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource NormalActionButtonStyle}">
        <Setter Property="Background" Value="#FFD54F"/> <!-- warm yellow -->
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="#FFB300"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.6"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <!-- Pulse only while enabled -->
            <Trigger Property="IsEnabled" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard x:Name="CtaPulseStoryboard">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1.0" To="0.78"
                                             Duration="0:0:0.7"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="CtaPulseStoryboard"/>
                </Trigger.ExitActions>
            </Trigger>

            <!-- If disabled, look disabled -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55"/>
            </Trigger>
        </Style.Triggers>
        </Style>

        <!-- Step card (boxed workflow group) -->
        <Style x:Key="StepCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0B2A66"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="BorderBrush" Value="#173B7A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>

        <!-- "STEP X" label -->
            <Style x:Key="StepLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Opacity" Value="0.80"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="2,0,0,6"/>
            </Style>
        
        <!-- Active step highlight -->
        <Style x:Key="ActiveStepCardStyle"
       TargetType="Border"
       BasedOn="{StaticResource StepCardStyle}">
            <Setter Property="BorderBrush" Value="#FFD54F"/>
            <Setter Property="BorderThickness" Value="4"/>
        </Style>


    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Locker Commissioning"
                   Foreground="White"
                   FontSize="44"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <!-- Controls (refactored into step cards) -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16" VerticalAlignment="Top">

            <!-- STEP 1: Connect -->
            <Border x:Name="Step1Card" Style="{StaticResource StepCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource StepLabelStyle}" Text="STEP 1 — Connect"/>
                    <Button x:Name="StartControllersButton"
                    Style="{StaticResource NormalActionButtonStyle}"
                    Content="Connect"
                    Width="125"
                    Height="60"
                    FontSize="20"
                    Click="StartControllers_Click"/>
                </StackPanel>
            </Border>

            <!-- STEP 2: Scan + OpenAll + Stop (boxed together) -->
            <Border x:Name="Step2Card"
        Style="{StaticResource StepCardStyle}"
        BorderBrush="#D6A11A"
        BorderThickness="3">
                <StackPanel>
                    <TextBlock Style="{StaticResource StepLabelStyle}" Text="STEP 2 — Open &amp; Detect Attached Doors"/>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Scan A -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                            <TextBlock Text="Scan A:" Foreground="White" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="−" Width="40" Height="40" FontSize="22" Click="ScanA_Decrease_Click"/>
                            <TextBlock x:Name="ScanAValueText"
                               Width="50"
                               Text="32"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20"
                               Foreground="White"
                               Margin="6,0"/>
                            <Button Content="+" Width="40" Height="40" FontSize="22" Click="ScanA_Increase_Click"/>
                        </StackPanel>

                        <!-- Scan B -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                            <TextBlock Text="Scan B:" Foreground="White" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="−" Width="40" Height="40" FontSize="22" Click="ScanB_Decrease_Click"/>
                            <TextBlock x:Name="ScanBValueText"
                               Width="50"
                               Text="32"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20"
                               Foreground="White"
                               Margin="6,0"/>
                            <Button Content="+" Width="40" Height="40" FontSize="22" Click="ScanB_Increase_Click"/>
                        </StackPanel>

                        <!-- Open / Stop -->
                        <Button x:Name="OpenAllButton"
                        Style="{StaticResource NormalActionButtonStyle}"
                        Content="Open All"
                        Width="125"
                        Height="60"
                        FontSize="20"
                        Margin="0,0,12,0"
                        Click="OpenAll_Click"
                        IsEnabled="False"/>

                        <Button x:Name="StopOpenAllButton"
                        Content="Stop"
                        Width="140"
                        Height="60"
                        FontSize="20"
                        Click="StopOpenAll_Click"
                        IsEnabled="False"/>
                    </StackPanel>

                    <TextBlock Foreground="White"
                       Opacity="0.70"
                       FontSize="14"
                       Margin="2,8,0,0"
                       Text="Tip: Run Open All so any connected doors/sensors can be detected as attached."/>
                </StackPanel>
            </Border>

            <!-- STEP 3: Assign Numbers -->
            <Border x:Name="Step3Card"
        Style="{StaticResource StepCardStyle}"
        BorderBrush="#D6A11A"
        BorderThickness="3">
                <StackPanel>
                    <TextBlock Style="{StaticResource StepLabelStyle}" Text="STEP 3 — Assign Numbers"/>
                    <Button x:Name="AssignNumbersButton"
                    Style="{StaticResource NormalActionButtonStyle}"
                    Content="Assign Numbers"
                    Width="140"
                    Height="60"
                    FontSize="20"
                    Click="AssignNumbers_Click"
                    IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- STEP 4: Confirm -->
            <Border x:Name="Step4Card"
        Style="{StaticResource StepCardStyle}"
        BorderBrush="#D6A11A"
        BorderThickness="3">
                <StackPanel>
                    <TextBlock Style="{StaticResource StepLabelStyle}" Text="STEP 4 — Confirm &amp; Save"/>
                    <Button x:Name="ConfirmedButton"
                    Style="{StaticResource NormalActionButtonStyle}"
                    Content="Confirm"
                    Width="125"
                    Height="60"
                    FontSize="20"
                    Click="Confirmed_Click"
                    IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- STEP 5: Exit -->
            <Border x:Name="Step5Card"
        Style="{StaticResource StepCardStyle}"
        BorderBrush="#D6A11A"
        BorderThickness="3">
                <StackPanel>
                    <TextBlock Style="{StaticResource StepLabelStyle}" Text="STEP 5 — Exit"/>
                    <Button x:Name="ExitButton"
                    Style="{StaticResource NormalActionButtonStyle}"
                    Content="Exit"
                    Width="125"
                    Height="60"
                    FontSize="20"
                    Click="Exit_Click"
                    IsEnabled="False"/>
                </StackPanel>
            </Border>

        </WrapPanel>

        <!-- Two grids (scrollable if needed) -->
        <ScrollViewer Grid.Row="2"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              PanningMode="VerticalOnly">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Branch A -->
                <Border Grid.Column="0"
                CornerRadius="10"
                Background="#0B2A66"
                Padding="16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                           Text="{Binding BranchATitle}"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="SemiBold"/>

                        <!-- Outer ItemsControl: 25 rows (boards) -->
                        <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding BranchAVisibleBoards}"
                              AlternationCount="25">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <!-- Board number -->
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="8"/>
                                            <!-- Ports -->
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Board number 1..25 -->
                                        <Border Grid.Column="0"
                                        CornerRadius="6"
                                        Background="#173B7A"
                                        Padding="6">
                                            <TextBlock Foreground="White"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                              Path=(ItemsControl.AlternationIndex),
                                                              Converter={StaticResource OneBasedIndexConverter}}"/>
                                        </Border>

                                        <!-- Inner ItemsControl: 8 ports -->
                                        <ItemsControl Grid.Column="2"
                                              ItemsSource="{Binding}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="8"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Margin="1"
                                                    Padding="4"
                                                    FontSize="14"
                                                    Height="34"
                                                    Content="{Binding DisplayLabel}"
                                                    Background="{Binding DisplayBrush}"
                                                    Foreground="Black"
                                                    Tag="{Binding RelayId}"
                                                    Click="Cell_Click"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Grid.Row="2"
                           Margin="0,12,0,0"
                           Foreground="White"
                           FontSize="18"
                           Text="{Binding BranchACountLine}"/>
                    </Grid>
                </Border>

                <!-- Spacer -->
                <Border Grid.Column="1" Background="Transparent"/>

                <!-- Branch B -->
                <Border Grid.Column="2"
                CornerRadius="10"
                Background="#0B2A66"
                Padding="16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                           Text="{Binding BranchBTitle}"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="SemiBold"/>

                        <!-- Outer ItemsControl: 25 rows (boards) -->
                        <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding BranchBVisibleBoards}"
                              AlternationCount="25">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Board number 1..25 -->
                                        <Border Grid.Column="0"
                                        CornerRadius="6"
                                        Background="#173B7A"
                                        Padding="6">
                                            <TextBlock Foreground="White"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                              Path=(ItemsControl.AlternationIndex),
                                                              Converter={StaticResource OneBasedIndexConverter}}"/>
                                        </Border>

                                        <!-- Inner ItemsControl: 8 ports -->
                                        <ItemsControl Grid.Column="2"
                                              ItemsSource="{Binding}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="8"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Margin="1"
                                                    Padding="4"
                                                    FontSize="14"
                                                    Height="34"
                                                    Content="{Binding Label}"
                                                    Background="{Binding DisplayBrush}"
                                                    Foreground="Black"
                                                    Tag="{Binding RelayId}"
                                                    Click="Cell_Click"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Grid.Row="2"
                           Margin="0,12,0,0"
                           Foreground="White"
                           FontSize="18"
                           Text="{Binding BranchBCountLine}"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>



        <!-- Status -->
        <TextBox Grid.Row="3"
                 x:Name="StatusText"
                 Margin="0,16,0,0"
                 Foreground="White"
                 Background="Transparent"
                 BorderThickness="0"
                 IsReadOnly="True"
                 IsHitTestVisible="False"
                 FontSize="20"
                 TextWrapping="Wrap"
                 Text="Ready."/>
    </Grid>
</Window>


