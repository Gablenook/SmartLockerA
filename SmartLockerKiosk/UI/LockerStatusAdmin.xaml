<Window x:Class="LockerStatusAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartLockerKiosk"
        mc:Ignorable="d"
        Title="Locker Status Admin"
        Width="800"
        Height="1200"
        WindowState="Normal"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="AdminButtonCompact" TargetType="Button">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid Background="#00205B">
        <Viewbox Stretch="Uniform">

            <Grid Width="800"
                  Height="1200"
                  Margin="0"
                  Background="#00205B">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Locker Status Admin"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="20,20,20,10"/>

                <TextBlock Grid.Row="1"
                           Text="Edit locker status. Select a locker, then use the action buttons."
                           FontSize="18"
                           Foreground="White"
                           TextWrapping="Wrap"
                           Margin="20,0,20,12"/>

                <Grid Grid.Row="2"
                      Margin="20,0,20,12">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Button area wraps instead of running off screen -->
                    <WrapPanel Grid.Row="0"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12">

                        <Button x:Name="ScanPortsButton"
                                Style="{StaticResource AdminButtonCompact}"
                                Content="Scan Ports"
                                Click="ScanPorts_Click"/>

                        <Button x:Name="ReloadButton"
                                Style="{StaticResource AdminButtonCompact}"
                                Content="Reload"
                                Click="Reload_Click"/>

                        <Button x:Name="ResetLockerButton"
                                Style="{StaticResource AdminButtonCompact}"
                                Content="Reset Locker"
                                Click="ResetLocker_Click"/>

                        <Button x:Name="MarkDefectiveButton"
                                Style="{StaticResource AdminButtonCompact}"
                                Content="Mark Defective"
                                Click="MarkDefective_Click"/>

                        <Button x:Name="ClearDefectiveButton"
                                Style="{StaticResource AdminButtonCompact}"
                                Content="Clear Defective"
                                Click="ClearDefective_Click"/>

                        <Button x:Name="OpenLockerButton"
                                Style="{StaticResource AdminButtonCompact}"
                                Content="Open Locker"
                                Click="OpenLocker_Click"/>

                        <Button x:Name="SaveButton"
                                Style="{StaticResource AdminButtonCompact}"
                                Content="Save"
                                Click="Save_Click"/>

                        <Button x:Name="CloseButton"
                                Style="{StaticResource AdminButtonCompact}"
                                Content="Close"
                                Click="Close_Click"/>
                    </WrapPanel>

                    <!-- DataGrid scrolls horizontally -->
                    <DataGrid x:Name="GridStatus"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="LockerId" Binding="{Binding LockerId}" IsReadOnly="True" Width="80"/>
                            <DataGridTextColumn Header="LockerNumber" Binding="{Binding LockerNumber}" IsReadOnly="True" Width="120"/>
                            <DataGridTextColumn Header="Branch" Binding="{Binding Branch}" IsReadOnly="True" Width="70"/>
                            <DataGridTextColumn Header="RelayId" Binding="{Binding RelayId}" IsReadOnly="True" Width="70"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeCode}" IsReadOnly="True" Width="70"/>

                            <DataGridComboBoxColumn Header="Occupancy"
                                                    SelectedItemBinding="{Binding OccupancyState, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="140"/>

                            <DataGridComboBoxColumn Header="Lock"
                                                    SelectedItemBinding="{Binding LockState, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="110"/>

                            <DataGridCheckBoxColumn Header="Package?"
                                                    Binding="{Binding PackagePresent, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="90"/>

                            <DataGridTextColumn Header="Asset Tag"
                                                Binding="{Binding CurrentAssetTag}"
                                                IsReadOnly="True"
                                                Width="130"/>

                            <DataGridTextColumn Header="Device Type"
                                                Binding="{Binding CurrentDeviceType}"
                                                IsReadOnly="True"
                                                Width="130"/>

                            <DataGridCheckBoxColumn Header="Defective?"
                                                    Binding="{Binding IsDefectiveHold}"
                                                    IsReadOnly="True"
                                                    Width="90"/>

                            <DataGridTextColumn Header="Reason"
                                                Binding="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                                                Width="200"/>

                            <DataGridTextColumn Header="ReservedUntilUtc"
                                                Binding="{Binding ReservedUntilUtc}"
                                                IsReadOnly="True"
                                                Width="160"/>

                            <DataGridTextColumn Header="Reserved WO"
                                                Binding="{Binding ReservedWorkOrderNumber}"
                                                IsReadOnly="True"
                                                Width="120"/>

                            <DataGridTextColumn Header="LastUpdatedUtc"
                                                Binding="{Binding LastUpdatedUtc}"
                                                IsReadOnly="True"
                                                Width="160"/>

                            <DataGridTextColumn Header="LastActorId"
                                                Binding="{Binding LastActorId}"
                                                IsReadOnly="True"
                                                Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Border Grid.Row="3"
                        Margin="20,0,20,20"
                        Padding="10"
                        Background="#FFEFEFEF"
                        CornerRadius="6">

                    <TextBlock x:Name="StatusText"
                               Text="Ready."
                               FontSize="16"/>
                </Border>
            </Grid>
        </Viewbox>
    </Grid>
</Window>