<Window x:Class="SmartLockerKiosk.TransactionRecoveryAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transaction Recovery"
        WindowStartupLocation="CenterOwner"
        Width="1200"
        Height="760"
        Background="#00205B">

    <Window.Resources>
        <Style x:Key="RecoveryButton" TargetType="Button">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Transaction Recovery"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Text="Review local transaction journals. Backend retry requires backend ACK support; local review and resolution are available here."
                   FontSize="17"
                   Foreground="White"
                   TextWrapping="Wrap"
                   Margin="0,0,0,14"/>

        <DataGrid x:Name="RecoveryGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="Created UTC" Binding="{Binding CreatedUtc}" Width="160"/>
                <DataGridTextColumn Header="Workflow" Binding="{Binding Workflow}" Width="150"/>
                <DataGridTextColumn Header="Action" Binding="{Binding ActionType}" Width="190"/>
                <DataGridTextColumn Header="Locker" Binding="{Binding LockerNumber}" Width="90"/>
                <DataGridTextColumn Header="Asset" Binding="{Binding AssetTag}" Width="140"/>
                <DataGridTextColumn Header="Device" Binding="{Binding DeviceType}" Width="120"/>
                <DataGridTextColumn Header="State" Binding="{Binding TransactionState}" Width="145"/>
                <DataGridTextColumn Header="ACK" Binding="{Binding AckStatus}" Width="110"/>
                <DataGridTextColumn Header="Retries" Binding="{Binding RetryCount}" Width="80"/>
                <DataGridTextColumn Header="Last Error" Binding="{Binding LastError}" Width="320"/>
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3"
                   Margin="0,14,0,0"
                   LastChildFill="True">

            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Left">
                <Button Content="Refresh"
                        Style="{StaticResource RecoveryButton}"
                        Click="Refresh_Click"/>
                <Button Content="Details"
                        Style="{StaticResource RecoveryButton}"
                        Click="Details_Click"/>
                <Button Content="Retry ACK"
                        Style="{StaticResource RecoveryButton}"
                        Click="RetryAck_Click"/>
                <Button Content="Needs Review"
                        Style="{StaticResource RecoveryButton}"
                        Click="NeedsReview_Click"/>
                <Button Content="Mark Resolved"
                        Style="{StaticResource RecoveryButton}"
                        Click="MarkResolved_Click"/>
                <Button Content="Integrity Report"
                        Style="{StaticResource RecoveryButton}"
                        Click="IntegrityReport_Click"/>
            </StackPanel>

            <Button Content="Close"
                    Style="{StaticResource RecoveryButton}"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"
                    Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>
